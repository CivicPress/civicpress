# CivicPress pnpm Configuration

# Use pnpm for package management
package-manager=pnpm

# Enable strict peer dependencies
strict-peer-dependencies=true

# Auto-install peer dependencies
auto-install-peers=true

# Use exact versions for better reproducibility
save-exact=true

# Enable workspace features
workspace-concurrency=4

# pnpm-managed Node for script execution — keep in sync with .nvmrc, or the
# build/lint steps run a different Node than the one setup-node/nvm provide.
use-node-version=22.22.3

# Enable pnpm store for better caching
store-dir=.pnpm-store

# Enable workspace protocol
link-workspace-packages=true

# Enable side effects cache
side-effects-cache=true
side-effects-cache-readonly=false

# Phase 2d W4-T2 (deps-010): strict hoisting — every workspace must declare every
# package it imports. Verified locally via scripts/audit-package-imports.mjs and
# `pnpm install --shamefully-hoist=false && pnpm -r build`. Do not flip back to
# `shamefully-hoist=true` without re-running the audit, or undeclared transitive
# imports will silently start resolving via the hoisted node_modules again.
shamefully-hoist=false
