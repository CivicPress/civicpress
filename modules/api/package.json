{
  "name": "@civicpress/api",
  "version": "1.0.0",
  "description": "REST API for CivicPress platform",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx --watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "civicpress",
    "api",
    "rest",
    "governance"
  ],
  "author": "CivicPress Team",
  "license": "MIT",
  "packageManager": "pnpm@10.12.4",
  "dependencies": {
    "@civicpress/core": "workspace:*",
    "@civicpress/storage": "workspace:*",
    "@types/bcrypt": "5.0.2",
    "@types/swagger-ui-express": "4.1.8",
    "bcrypt": "6.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "express": "^4.22.2",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.3.2",
    "helmet": "^7.2.0",
    "js-yaml": "4.1.0",
    "morgan": "^1.10.1",
    "multer": "1.4.5-lts.2",
    "swagger-ui-express": "5.0.1"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/js-yaml": "4.0.9",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^1.4.13",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^9.39.4",
    "supertest": "^6.3.4",
    "tsx": "^4.22.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
