{
  "name": "@civicpress/cli",
  "version": "1.0.0",
  "description": "CivicPress Command Line Interface",
  "type": "module",
  "main": "dist/progressive.js",
  "bin": {
    "civic": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:progressive": "tsc src/progressive.ts --outDir dist --target es2022 --module esnext --moduleResolution node",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/**/*.ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "civic",
    "government",
    "cli"
  ],
  "author": "CivicPress Team",
  "license": "MIT",
  "dependencies": {
    "@civicpress/core": "workspace:*",
    "@civicpress/storage": "workspace:*",
    "@types/diff": "8.0.0",
    "bcrypt": "6.0.0",
    "cac": "^6.7.14",
    "chalk": "^5.6.2",
    "diff": "8.0.2",
    "form-data": "^4.0.5",
    "fs-extra": "^11.3.5",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "inquirer": "^9.3.8",
    "mime-types": "^2.1.35",
    "node-fetch": "^3.3.2",
    "simple-git": "^3.36.0",
    "tar": "^6.2.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/bcrypt": "5.0.2",
    "@types/fs-extra": "^11.0.4",
    "@types/glob": "9.0.0",
    "@types/inquirer": "9.0.8",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^20.19.41",
    "@types/node-fetch": "^2.6.13",
    "@types/tar": "6.1.13",
    "@typescript-eslint/eslint-plugin": "8.36.0",
    "@typescript-eslint/parser": "8.36.0",
    "eslint": "9.30.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.12.4"
}
