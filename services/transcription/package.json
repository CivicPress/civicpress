{
  "name": "@civicpress/transcription",
  "version": "0.1.0",
  "description": "Optional CivicPress transcription worker (BroadcastBox W2): polls session records for captured A/V and writes back a transcript. Engine-pluggable (whisper.cpp default).",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "test:run": "vitest run",
    "clean": "rm -rf dist"
  },
  "license": "AGPL-3.0-or-later",
  "devDependencies": {
    "@types/node": "^20.19.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
