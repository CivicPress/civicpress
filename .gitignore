# Node
node_modules/
.pnpm/
*.log

# OS
.DS_Store
Thumbs.db

# IDEs
.vscode/*
!.vscode/settings.json

# Runtime
.env
dist/
build/
.cache/
.nyc_output/

# Nuxt build artifacts
.nuxt/
.output/

# Compiled JavaScript files
*.js
*.js.map
*.d.ts
*.d.ts.map

# Exception: hand-written source declaration, NOT a generated artifact.
# The Express.Request global augmentation is real source and MUST be tracked —
# otherwise the repo cannot build from a clean checkout (a fresh `git worktree`
# exposes this). The `*.d.ts` rule above is for generated declarations, which
# live in the already-ignored dist/.
!modules/api/src/types/express-augment.d.ts

# TypeScript build cache
*.tsbuildinfo

# CivicPress Private System Data (never in Git)
.system-data/
*.db
*.log

# CivicPress Local Configuration (machine-specific, generated by civic init)
.civicrc

# CivicPress Public Data (separate Git repository)
# data/ folder has its own Git repository and should not be tracked here
data/
# Only ignore storage/ at root (runtime files), not modules/storage/ (source code)
/storage/
exports/backups/

# Test-run storage artifacts (modules/storage/.test-storage/ etc).
# Tests create local file fixtures here; the test-cleanup story is
# tracked as a W2-T18 storage-decomposition follow-up.
**/.test-storage/

# Agent / IDE local state (per-machine; not for the repo).
.claude/

# pnpm
# Note: pnpm-lock.yaml should be committed for reproducible builds
.pnpm-store/

# Mac system files
Icon?
._*

# backup exports
*.zip

# BroadcastBox live-e2e harness throwaway data
/.e2e-live/
