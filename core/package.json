{
  "name": "@civicpress/core",
  "version": "1.0.0",
  "description": "CivicPress Core Platform",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && npm run build:copy-schemas",
    "build:copy-schemas": "mkdir -p dist/schemas/record-type-schemas dist/modules && cp -r src/schemas/*.json dist/schemas/ 2>/dev/null || true && cp -r src/schemas/record-type-schemas/*.json dist/schemas/record-type-schemas/ 2>/dev/null || true && cp src/modules/module.schema.json dist/modules/ 2>/dev/null || true",
    "dev": "tsc --watch",
    "dev:build": "tsc && tsc --watch",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/**/*.ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "civic",
    "government",
    "core"
  ],
  "author": "CivicPress Team",
  "license": "MIT",
  "dependencies": {
    "@octokit/rest": "^21.1.1",
    "@sendgrid/mail": "8.1.5",
    "@types/jsonwebtoken": "9.0.10",
    "ajv": "8.17.1",
    "ajv-formats": "3.0.1",
    "bcrypt": "6.0.0",
    "chalk": "^5.6.2",
    "fast-levenshtein": "3.0.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "4.3.0",
    "jsonwebtoken": "9.0.2",
    "lru-cache": "11.2.4",
    "nodemailer": "7.0.13",
    "octokit": "^5.0.5",
    "simple-git": "^3.36.0",
    "sqlite3": "5.1.7",
    "tar": "^6.2.1",
    "uuid": "^11.1.0",
    "yaml": "^2.9.0"
  },
  "peerDependencies": {
    "@civicpress/storage": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@civicpress/storage": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/bcrypt": "5.0.2",
    "@types/js-yaml": "4.0.9",
    "@types/lru-cache": "7.10.10",
    "@types/node": "^20.19.41",
    "@types/tar": "6.1.13",
    "@types/uuid": "10.0.0",
    "@typescript-eslint/eslint-plugin": "8.36.0",
    "@typescript-eslint/parser": "8.36.0",
    "eslint": "9.30.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.12.4"
}
